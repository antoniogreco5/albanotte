# Shopify Storefront API
# Get your token: Shopify Admin → Settings → Apps → Develop apps → Create an app
# → Configure Storefront API scopes → Install → Copy the Storefront access token
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=albanotte.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Optional: Shopify Admin API (for webhooks / revalidation)
# SHOPIFY_ADMIN_ACCESS_TOKEN=your_admin_token_here
# SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here
